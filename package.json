{
  "name": "vizidot-2.0",
  "version": "1.0.0",
  "description": "Vizidot 2.0 - Backend and Admin Panel",
  "scripts": {
    "start:backend": "cd backend && npm run dev",
    "start:admin": "cd admin-panel && npm start",
    "start:api": "cd app-api && npm run dev",
    "start": "concurrently \"npm run start:backend\" \"npm run start:admin\"",
    "install:all": "cd backend && npm install && cd ../admin-panel && npm install",
    "firebase": "firebase",
    "deploy:functions": "firebase deploy --only functions"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "firebase-tools": "^13.0.0"
  }
}

